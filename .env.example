# ============================================
# Laris.AI — Environment Variables
# ============================================
# Salin file ini ke `.env.local` dan isi nilainya.
# JANGAN commit `.env.local` ke Git!

# --------------------------------------------
# Supabase (WAJIB untuk FASE 1)
# --------------------------------------------
# Buat project baru di https://supabase.com/dashboard
# Settings → API → salin URL & keys di sini

NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6..."

# --------------------------------------------
# FastAPI Bot (untuk FASE 5: AI Chat + Print)
# --------------------------------------------
# Backend WA bot yang sudah ada di bukuwarung-ai/kita-cuan-wa-bot/
# Deploy di Railway, lalu copy URL di sini.

FASTAPI_BOT_URL="https://bukuwarung-ai-larisai.up.railway.app"

# --------------------------------------------
# Vercel AI SDK / Groq (untuk FASE 5: AI Chat)
# --------------------------------------------
# Groq gratis untuk development. Daftar di https://console.groq.com

GROQ_API_KEY="gsk_xxxxx"

# --------------------------------------------
# Opsional: Analytics (FASE 7)
# --------------------------------------------
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""
